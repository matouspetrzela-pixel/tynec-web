{
  "name": "tynec-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev": "next dev -p 3000",
    "dev:turbo": "next dev -p 3000 --turbo",
    "dev:webpack": "next dev -p 3000",
    "dev:clean": "npm run clean && next dev -p 3000",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/assert-production-deploy.mjs && next build",
