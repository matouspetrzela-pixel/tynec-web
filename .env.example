# Volitelne: URL Facebook stranky (vychozi hodnota je v lib/social.ts)
# NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/...

# Google Analytics 4 — Measurement ID z Admin → Data streams → váš web.
# Ve streamu nastavte URL https://protynecsrdcem.cz (stejna domena jako canonical v kodu).
# Po nasazeni: GA4 Reports + Looker Studio (propojeni GA4 jako zdroj) pro vlastni dashboard.
# Vlastni udalosti pro konverze (GA4 Admin -> Klíčové události):
#   cta_podporte, cta_facebook, cta_email, support_card_nav, cta_hero_link
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Interní dashboard (GA4 Data API): samostatný projekt webobec/tynec-analytics — viz jeho README.md a .env.example.

# ── Vercel Production (nastavuje se v dashboardu projektu, ne v .env.local) ──
# Bez teto promenne produkcni build na Vercelu zamerne selze (ochrana pred predcasnym live).
# ALLOW_PRODUCTION_DEPLOY=true

